{
  "name": "releaseproof",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "description": "Proof-carrying data release autopilot powered by Qwen Cloud.",
  "homepage": "https://github.com/xiaodouzi666/releaseproof#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiaodouzi666/releaseproof.git"
  },
  "bugs": {
    "url": "https://github.com/xiaodouzi666/releaseproof/issues"
  },
  "keywords": [
    "qwen-cloud",
    "autopilot-agent",
    "data-release",
    "human-in-the-loop",
    "audit-trail"
  ],
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "tsx watch server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "eval": "tsx scripts/run-evaluation.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.25.0",
    "nanoid": "^6.0.0",
    "openai": "^6.48.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
