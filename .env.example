# Qwen Cloud (server-side only)
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
QWEN_FALLBACK_MODEL=qwen3.6-flash
QWEN_MAX_CONCURRENCY=2

# Server
PORT=8787
AUDIT_STORE=file
RELEASEPROOF_DATA_FILE=./data/releaseproof-store.json
DEMO_STEP_DELAY_MS=420
DEPLOYMENT_TARGET=local
# Leave empty for same-origin only. Set a comma-separated allow-list only when
# a separately hosted frontend must call this API.
CORS_ORIGINS=
WORKFLOW_CREATE_LIMIT_PER_MINUTE=12
