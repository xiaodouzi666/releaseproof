# Install the real file as /etc/releaseproof/releaseproof.env with mode 0600.
# Never commit, print, record, or upload the populated file.
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
QWEN_FALLBACK_MODEL=qwen3.6-flash
QWEN_MAX_CONCURRENCY=2
DEMO_STEP_DELAY_MS=120
WORKFLOW_CREATE_LIMIT_PER_MINUTE=1
