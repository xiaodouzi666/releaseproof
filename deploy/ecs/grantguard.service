[Unit]
Description=GrantGuard Docker Compose application
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/grantguard
ExecStart=/usr/bin/docker compose -f deploy/ecs/docker-compose.prod.yml up -d --remove-orphans
ExecStop=/usr/bin/docker compose -f deploy/ecs/docker-compose.prod.yml down
TimeoutStartSec=0
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target
